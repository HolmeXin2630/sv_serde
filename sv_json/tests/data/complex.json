{
  "project": {
    "name": "sv_serde",
    "version": "1.0.0",
    "authors": ["alice", "bob", "charlie"],
    "config": {
      "debug": false,
      "timeout_ms": 5000,
      "retries": 3,
      "tags": ["json", "yaml", "sv"],
