    "int_large": 9999999999,
    "float_pi": 3.14159265358979,
    "float_small": 0.001,
    "string_empty": "",
    "string_unicode": "hello 世界",
    "array_empty": [],
    "object_empty": {},
    "deep_nested": {
      "l1": {"l2": {"l3": {"l4": {"l5": {"value": "deep"}}}}}
    }
